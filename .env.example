# ============================================================
# 新闻公司(情报部门) 环境变量模板
# 复制为 .env 后填入真实值，.env 已在 .gitignore 中
# GitHub Actions 中通过 repo Secrets 注入，无需 .env 文件
# ============================================================

# --- LLM ---
ANTHROPIC_API_KEY=sk-ant-api03-xxxx          # Anthropic Claude Sonnet API Key (news-company)

# --- 推送 ---
SERVERCHAN_KEY=SCTxxxxx                      # Server酱 SendKey (微信推送)

# --- 数据库 ---
SUPABASE_URL=https://xxxx.supabase.co        # Supabase 项目 URL
SUPABASE_KEY=eyJxxx                          # Supabase service_role JWT

# --- 审核员专用 ---
GH_TOKEN=gho_xxxx                            # GitHub Token (查询 Actions 状态)
